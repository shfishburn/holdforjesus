{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-og-images.mjs",
    "build": "vite build",
    "postbuild": "test -n \"$VERCEL\" || react-snap",
    "build:dev": "vite build --mode development",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false .",
    "deno:fmt": "deno task fmt",
    "deno:fmt:check": "deno task fmt:check",
    "deno:lint": "deno task lint",
    "deno:check": "deno task check",
    "db:link": "sh scripts/supabase-link.sh",
    "db:push": "sh scripts/supabase-push.sh",
    "db:copy:data": "sh scripts/supabase-copy-data.sh",
    "types:supabase": "sh scripts/gen-supabase-types.sh",
    "types:supabase:local": "sh -c 'tmp=$(mktemp) && supabase gen types typescript --local --schema public > \"$tmp\" && mv \"$tmp\" src/integrations/supabase/types.ts'",
    "types:supabase:dburl": "sh -c 'if [ -z \"$SUPABASE_DB_URL\" ]; then echo \"SUPABASE_DB_URL is required\" >&2; exit 2; fi; tmp=$(mktemp) && supabase gen types typescript --db-url \"$SUPABASE_DB_URL\" --schema public > \"$tmp\" && mv \"$tmp\" src/integrations/supabase/types.ts'",
    "types:supabase:project": "sh -c 'if [ -z \"$SUPABASE_PROJECT_ID\" ]; then echo \"SUPABASE_PROJECT_ID is required\" >&2; exit 2; fi; tmp=$(mktemp) && supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > \"$tmp\" && mv \"$tmp\" src/integrations/supabase/types.ts'",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.83.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.35.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.61.1",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.9",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^20.0.3",
    "postcss": "^8.5.6",
    "react-snap": "^1.23.0",
    "sharp": "^0.34.5",
    "supabase": "^2.77.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19",
    "vitest": "^3.2.4"
  },
  "reactSnap": {
    "source": "dist",
    "include": [
      "/",
      "/about",
      "/transparency",
      "/privacy",
      "/terms",
      "/community",
      "/crisis",
      "/observatory",
      "/incidents"
    ],
    "inlineCss": false,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  }
}
